{
  "name": "playwright-demo",
  "version": "2.0.0",
  "description": "Enterprise-grade Playwright automation framework",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project=chromium-all",
    "test:firefox": "npx playwright test --project=firefox-all",
    "test:webkit": "npx playwright test --project=webkit-login",
    "test:api": "npx playwright test tests/REST-API",
    "test:login": "npx playwright test tests/playwrightdemo tests/datadriventestinglogin tests/datadriventestingloginusingtags",
    "test:table": "npx playwright test tests/test-table-playwright",
    "test:exceptions": "npx playwright test tests/Test-Exceptions-playwright",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-playwright": "^3.7.1"
  }
}
